---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<section class="pt-6 pb-10 md:pt-8 md:pb-14 text-center">
  <h1 class="text-4xl md:text-5xl font-bold mb-4 text-ink font-display">{title}</h1>
  {subtitle && <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto">{subtitle}</p>}
</section>
