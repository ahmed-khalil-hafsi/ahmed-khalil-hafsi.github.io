---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.webp';

const essays = [
	{
		title: "Strategic Silence and Negotiation Agents: Teach Your AI to Shut Up",
		blurb: "Where agentic engineering meets negotiation, and why knowing when to stay quiet is a feature.",
		url: "https://negotiations.substack.com",
	},
	{
		title: "Negotiating in the Age of LLMs",
		blurb: "A practical framework for winning when the counterparty runs on probability.",
		url: "https://negotiations.substack.com",
	},
	{
		title: "How to Negotiate with Trump: 3 Game-Theory Strategies",
		blurb: "Credible commitments, exit options, and strategic signaling in high-stakes deals.",
		url: "https://negotiations.substack.com/p/how-to-negotiate-with-trump-game-theory",
	},
	{
		title: "Solving Complexity in Global Diplomacy: The Iran Nuclear Negotiations",
		blurb: "How embracing complexity produces durable diplomatic outcomes.",
		url: "https://negotiations.substack.com/p/solving-complexity-in-global-diplomacy",
	},
];

const tools = [
	{
		name: "P2Predict",
		blurb: "Parametric price benchmarking for engineering and procurement trade-offs. Agentic first, runs on your data, stays on your machine.",
		license: "Source-available under the PolyForm Noncommercial License 1.0.0",
		url: "https://p2predict.com",
	},
	{
		name: "P2CLPFD",
		blurb: "P2CLPFD is an agentic-first, open source, dynamic programming framework that enables decisions on complex supplier allocation problems.",
		license: "GPLv3",
		url: "https://github.com/ahmed-khalil-hafsi/P2CLPFD",
	},
];
---

<Layout
	description="Ahmed Khalil Hafsi (Ahmed K. Hafsi) on negotiation and game theory: how power, incentives, and leverage shape outcomes in business, technology, and geopolitics."
>
	<div class="max-w-3xl mx-auto px-4 sm:px-6">
		<!-- Intro -->
		<section class="pt-12 md:pt-16">
			<div class="flex items-center gap-5 mb-8">
				<Image
					src={profileImage}
					alt="Ahmed K. Hafsi"
					class="w-24 h-24 md:w-28 md:h-28 object-cover rounded-full border border-rule flex-shrink-0"
					width={256}
					height={256}
					quality={88}
					loading="eager"
				/>
				<div>
					<h1 class="font-display text-3xl md:text-4xl font-bold text-ink tracking-tight">Ahmed K. Hafsi</h1>
					<p class="text-muted mt-1 text-base md:text-lg">Negotiation · Game Theory · Strategy · APAC (Singapore)</p>
				</div>
			</div>

			<p class="text-xl md:text-2xl leading-snug text-ink font-display">
				I turn negotiation into a system: the leverage, incentives, and terms that decide who captures value, made explicit and engineered.
			</p>

			<div class="mt-6 space-y-4 text-ink/90">
				<p>
					I build negotiation operating models that turn scattered deal-making into a disciplined capability, and I lead high-stakes negotiations where the result has to show up in the P&amp;L. The work blends game theory, behavioral science, and hard data with operational reality, from factory-floor constraints to boardroom approvals.
				</p>
				<p>
					My focus is industrials across the Asia-Pacific, from automotive and semiconductors to consumer tech and chemicals. Singapore is my launch pad, and I work all over the region, from Japan to Indonesia.
				</p>
			</div>
		</section>

		<hr class="my-12 border-rule" />

		<!-- What I bring -->
		<section>
			<h2 class="font-display text-2xl md:text-3xl font-semibold text-ink mb-5">What I bring</h2>
			<div class="border-l-2 border-accent pl-5 space-y-3 text-ink/90">
				<p><strong>Deal architecture.</strong> Pricing, indexation, and terms that hold value over years, not just on signing day.</p>
				<p><strong>Leverage and incentives.</strong> Game-theoretic analysis of who really holds power, and why.</p>
				<p><strong>Negotiation operating models.</strong> Turning ad-hoc deal-making into a repeatable, governed capability.</p>
				<p><strong>Finance-validated value.</strong> Outcomes measured in gross margin, EBITDA, and cash.</p>
			</div>
			<p class="mt-6 text-ink/90">
				I go deeper on how I think about negotiation, game theory, and AI on the <a href="/about">about page</a>.
			</p>
		</section>

		<hr class="my-12 border-rule" />

		<!-- Writing -->
		<section>
			<div class="flex items-baseline justify-between mb-5 gap-4">
				<h2 class="font-display text-2xl md:text-3xl font-semibold text-ink">Selected writing</h2>
				<a href="/newsletter" class="text-accent text-sm whitespace-nowrap">All essays →</a>
			</div>
			<ul class="space-y-5">
				{essays.map((e) => (
					<li>
						<a href={e.url} target="_blank" rel="noopener noreferrer" class="font-display text-lg text-ink hover:text-accent transition-colors">
							{e.title}
						</a>
						<p class="text-muted mt-1">{e.blurb}</p>
					</li>
				))}
			</ul>
		</section>

		<hr class="my-12 border-rule" />

		<!-- Tools -->
		<section>
			<h2 class="font-display text-2xl md:text-3xl font-semibold text-ink mb-3">Open-source tools</h2>
			<p class="text-muted mb-5">Bringing game-theoretic thinking and data science to procurement and supply-chain decisions.</p>
			<ul class="space-y-5">
				{tools.map((t) => (
					<li>
						<a href={t.url} target="_blank" rel="noopener noreferrer" class="font-display text-lg text-ink hover:text-accent transition-colors">
							{t.name}
						</a>
						<p class="text-muted mt-1">{t.blurb}</p>
						{t.license && <p class="text-subtle text-sm mt-1">{t.license}</p>}
					</li>
				))}
			</ul>
		</section>

		<hr class="my-12 border-rule" />

		<!-- Closer -->
		<section class="pb-4">
			<p class="text-ink/90">
				Reach me via the <a href="/contact">contact page</a> or on
				<a href="https://www.linkedin.com/in/ahmedkhalilhafsi/" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
			</p>
		</section>
	</div>
</Layout>
