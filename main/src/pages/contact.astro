---
import Layout from '../layouts/Layout.astro';

const channels = [
  {
    label: "LinkedIn",
    value: "linkedin.com/in/ahmedkhalilhafsi",
    href: "https://www.linkedin.com/in/ahmedkhalilhafsi/",
    path: "M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4",
  },
  {
    label: "Substack",
    value: "negotiations.substack.com",
    href: "https://negotiations.substack.com",
    path: "M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z",
  },
];

const topics = ["Negotiation", "Game Theory", "Behavioral Economics", "Procurement Strategy", "Supply Chain", "Geopolitics"];

// Web3Forms access key. Get a free key at https://web3forms.com (enter your
// email, they send you a key) and paste it below. The key is public by design;
// it only routes submissions to your inbox, so it is safe to commit.
const WEB3FORMS_ACCESS_KEY = "8dd122f8-111e-4636-b691-deec928bec3d";

const inputClass = "w-full px-3 py-2 bg-paper border border-rule rounded-md text-ink placeholder:text-subtle focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors";
---

<Layout
  title="Contact - Ahmed K. Hafsi"
  description="Get in touch with Ahmed K. Hafsi about writing, speaking, or ideas on negotiation and game theory."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-12 md:pt-16">
    <h1 class="text-4xl md:text-5xl font-bold font-display text-ink mb-10 md:mb-12">Get in Touch</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12">
      <div>
        <h2 class="text-xl md:text-2xl font-semibold mb-4 md:mb-6 font-display text-ink">Contact information</h2>
        <p class="text-muted mb-8">
          Happy to hear from readers, fellow practitioners, and anyone working on interesting problems, whether about an essay, a speaking invitation, or an idea worth comparing notes on. Reach me through any of these channels:
        </p>

        <div class="space-y-4">
          {channels.map((c) => (
            <div class="flex items-start">
              <div class="text-accent mr-3 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={c.path} />
                </svg>
              </div>
              <div>
                <p class="font-medium text-ink">{c.label}</p>
                <a href={c.href} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">{c.value}</a>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <h3 class="text-lg font-semibold mb-4 font-display text-ink">Topics I think about</h3>
          <div class="flex flex-wrap gap-2">
            {topics.map((t) => (
              <span class="px-3 py-1 bg-card border border-rule rounded-full text-sm text-ink">{t}</span>
            ))}
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-xl md:text-2xl font-semibold mb-4 md:mb-6 font-display text-ink">Send a message</h2>
        <p class="text-muted mb-4">Fill out the form below and I'll respond personally.</p>

        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
          <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
          <input type="hidden" name="subject" value="New message from ahmedhafsi.com" />
          <input type="hidden" name="from_name" value="ahmedhafsi.com contact form" />
          <!-- Honeypot: bots fill this hidden field; real users never see it -->
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

          <div>
            <label for="name" class="block text-sm text-muted mb-1">Name</label>
            <input id="name" name="name" type="text" required autocomplete="name" class={inputClass} />
          </div>
          <div>
            <label for="email" class="block text-sm text-muted mb-1">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" class={inputClass} />
          </div>
          <div>
            <label for="message" class="block text-sm text-muted mb-1">Message</label>
            <textarea id="message" name="message" rows="6" required class={inputClass}></textarea>
          </div>

          <button type="submit" class="px-6 py-2.5 bg-accent text-paper rounded-md hover:bg-accentDark transition-colors font-medium disabled:opacity-60 disabled:cursor-not-allowed">
            Send message
          </button>
          <p id="form-status" class="text-sm mt-2" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('form-status');
    if (form && status) {
      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const original = button.textContent;
        button.disabled = true;
        button.textContent = 'Sending...';
        status.className = 'text-sm mt-2 text-muted';
        status.textContent = '';

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          const data = await response.json();
          if (response.ok) {
            form.reset();
            status.className = 'text-sm mt-2 text-accent';
            status.textContent = "Thanks, your message is on its way. I'll get back to you personally.";
          } else {
            status.className = 'text-sm mt-2 text-red-700';
            status.textContent = data.message || 'Something went wrong. Please email me directly instead.';
          }
        } catch {
          status.className = 'text-sm mt-2 text-red-700';
          status.textContent = 'Network error. Please email me directly instead.';
        } finally {
          button.disabled = false;
          button.textContent = original;
        }
      });
    }
  </script>
</Layout>
