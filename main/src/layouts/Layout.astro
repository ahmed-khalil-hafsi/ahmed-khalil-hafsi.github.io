---
interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	canonicalURL?: string;
	noindex?: boolean;
}

const {
	title = "Ahmed Khalil Hafsi (Ahmed K. Hafsi) - Negotiation & Game Theory",
	description = "Ahmed Khalil Hafsi (Ahmed K. Hafsi) on negotiation, game theory, and strategy: how power, incentives, and leverage shape outcomes in business, technology, and geopolitics.",
	ogImage = "/og-image.png",
	canonicalURL,
	noindex = false,
} = Astro.props;

const resolvedCanonical = canonicalURL ?? `https://ahmedhafsi.com${Astro.url.pathname}`;
const ogImageURL = new URL(ogImage, "https://ahmedhafsi.com").href;
const currentYear = new Date().getFullYear();

const navLinks = [
	{ href: "/", label: "Home" },
	{ href: "/newsletter", label: "Games & Negotiations" },
	{ href: "/about", label: "About" },
	{ href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- preload heading font -->
		<link rel="preload" href="/fonts/source-serif-pro/source-serif-pro-600.woff2" as="font" type="font/woff2" crossorigin>
		<link rel="preload" href="/fonts/source-serif-pro/source-serif-pro-700.woff2" as="font" type="font/woff2" crossorigin>

		<!-- SEO Meta Tags -->
		<meta name="description" content={description} />
		<meta name="keywords" content="game theory, negotiation, strategy, leverage, behavioral economics, geopolitics, Ahmed Hafsi" />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Open Graph / Social Media Meta Tags -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:url" content={resolvedCanonical} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<!-- Umami Analytics -->
		<script defer src="https://cloud.umami.is/script.js" data-website-id="c38fb1f4-0eda-4784-8957-2792fb2474ba"></script>

		<link rel="canonical" href={resolvedCanonical} />

		<!-- RSS feed discovery -->
		<link rel="alternate" type="application/rss+xml" title="Games & Negotiations by Ahmed K. Hafsi" href="/rss.xml" />
	</head>
	<body class="bg-paper text-ink font-serif min-h-screen flex flex-col">
		<header class="w-full py-6 px-4 md:px-8 border-b border-rule">
			<div class="max-w-3xl mx-auto flex flex-col md:flex-row items-center gap-4 md:gap-0 md:justify-between">
				<div class="w-full md:w-auto flex justify-between items-center">
					<a href="/" class="font-display text-lg md:text-xl font-semibold text-ink hover:text-accent transition-colors tracking-tight">
						Ahmed K. Hafsi
					</a>
					<button id="menuBtn" aria-label="Toggle menu" class="md:hidden text-ink">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
				</div>
				<nav id="mobileNav" class="w-full md:w-auto hidden md:block">
					<ul class="flex flex-col md:flex-row gap-2 md:gap-7 items-center text-[0.95rem]">
						{navLinks.map((link) => {
							const active = link.href === "/" ? path === "/" : path.startsWith(link.href);
							return (
								<li>
									<a
										href={link.href}
										class:list={[
											"block py-1 md:py-0 transition-colors whitespace-nowrap hover:text-accent",
											active ? "text-accent" : "text-muted",
										]}
									>
										{link.label}
									</a>
								</li>
							);
						})}
					</ul>
				</nav>
			</div>
		</header>

		<main class="flex-grow w-full">
			<slot />
		</main>

		<footer class="py-10 px-4 mt-16 border-t border-rule">
			<div class="max-w-3xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
				<p class="text-sm text-subtle">© {currentYear} Ahmed Khalil Hafsi</p>
				<div class="flex gap-6 text-sm">
					<a href="https://negotiations.substack.com" target="_blank" rel="noopener" class="text-muted hover:text-accent transition-colors">Substack</a>
					<a href="https://www.linkedin.com/in/ahmedkhalilhafsi/" target="_blank" rel="noopener" class="text-muted hover:text-accent transition-colors">LinkedIn</a>
					<a href="https://github.com/ahmed-khalil-hafsi" target="_blank" rel="noopener" class="text-muted hover:text-accent transition-colors">GitHub</a>
					<a href="/rss.xml" class="text-muted hover:text-accent transition-colors">RSS</a>
				</div>
			</div>
		</footer>

		<!-- Structured Data for SEO -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Ahmed Khalil Hafsi",
			"alternateName": "Ahmed K. Hafsi",
			"url": "https://ahmedhafsi.com",
			"image": "https://ahmedhafsi.com/og-image.png",
			"sameAs": [
				"https://negotiations.substack.com",
				"https://www.linkedin.com/in/ahmedkhalilhafsi/",
				"https://github.com/ahmed-khalil-hafsi"
			],
			"jobTitle": "Senior Manager, Negotiation Excellence",
			"worksFor": { "@type": "Organization", "name": "Infineon Technologies" },
			"alumniOf": { "@type": "CollegeOrUniversity", "name": "Karlsruhe Institute of Technology" },
			"homeLocation": { "@type": "Place", "name": "Asia-Pacific (Singapore)" },
			"knowsAbout": ["Negotiation", "Game Theory", "Behavioral Economics", "Procurement Strategy", "Supply Chain", "Automotive", "Semiconductors", "Consumer Technology", "Chemicals", "Geopolitics"],
			"description": "Works on negotiation and applied game theory, exploring how power, incentives, and leverage shape outcomes in business, technology, and geopolitics."
		})} />

		<script>
			// Mobile menu toggle
			document.addEventListener('DOMContentLoaded', () => {
				const menuBtn = document.getElementById('menuBtn');
				const mobileNav = document.getElementById('mobileNav');
				if (menuBtn && mobileNav) {
					menuBtn.addEventListener('click', () => {
						mobileNav.classList.toggle('hidden');
					});
				}
			});
		</script>
	</body>
</html>

<style is:global>
	html {
		font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Book Antiqua', Georgia, Cambria, serif;
		font-size: 19px;
		line-height: 1.7;
		-webkit-text-size-adjust: 100%;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}
	body {
		margin: 0;
		width: 100%;
	}
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Source Serif Pro', Georgia, serif;
		line-height: 1.2;
	}

	@media (max-width: 640px) {
		html { font-size: 17px; }
	}

	/* Improve touch targets on mobile */
	@media (max-width: 640px) {
		button,
		[role="button"],
		a.button,
		input[type="submit"] {
			min-height: 44px;
		}
	}

	/* Source Serif Pro: display headings */
	@font-face {
		font-family: 'Source Serif Pro';
		font-style: normal;
		font-weight: 600;
		font-display: swap;
		src: url('/fonts/source-serif-pro/source-serif-pro-600.woff2') format('woff2');
	}
	@font-face {
		font-family: 'Source Serif Pro';
		font-style: normal;
		font-weight: 700;
		font-display: swap;
		src: url('/fonts/source-serif-pro/source-serif-pro-700.woff2') format('woff2');
	}

	/* Inter: small uppercase labels only */
	@font-face {
		font-display: swap;
		font-family: 'Inter';
		font-style: normal;
		font-weight: 500;
		src: url('/fonts/inter/inter-v18-latin-500.woff2') format('woff2');
	}
</style>
