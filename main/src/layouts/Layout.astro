---
interface Props {
	title?: string;
}

const { title = "Ahmed K. Hafsi - Negotiation Strategist" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		
		<!-- preload the fonts -->

		<link rel="preload" href="/fonts/inter/inter-v18-latin-regular.woff2" as="font" type="font/woff2" crossorigin>
		<link rel="preload" href="/fonts/inter/inter-v18-latin-500.woff2" as="font" type="font/woff2" crossorigin>
		<link rel="preload" href="/fonts/source-serif-pro/source-serif-pro-600.woff2" as="font" type="font/woff2" crossorigin>
		

		<!-- SEO Meta Tags -->
		<meta name="description" content="Ahmed K. Hafsi - Expert in game theory and negotiation strategy with over a decade of experience in global procurement and sales negotiations." />
		<meta name="keywords" content="game theory, negotiation, strategic advisory, procurement, behavioral economics, Ahmed Hafsi" />
		
		<!-- Open Graph / Social Media Meta Tags -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Expert insights on game theory and negotiation strategy" />
		<meta property="og:image" content="/og-image.jpg" />
		<meta property="og:url" content="https://ahmedhafsi.com" />
		<meta name="twitter:card" content="summary_large_image" />

		<!-- Umami Analytics -->
		<script defer src="https://cloud.umami.is/script.js" data-website-id="c38fb1f4-0eda-4784-8957-2792fb2474ba"></script>

		<link rel="canonical" href={`https://ahmedhafsi.com${Astro.url.pathname}`} />
	</head>
	<body class="bg-dark text-white font-sans min-h-screen flex flex-col">
		<header class="w-full py-6 px-4 md:px-8 bg-dark border-b border-gray-800">
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-6 md:gap-0 md:justify-between">
				<div class="w-full flex justify-between items-center">
					<a href="/" class="text-xl font-bold text-white hover:text-accent transition-colors">
						Ahmed K. Hafsi
					</a>
					<button id="menuBtn" class="md:hidden text-white">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
				</div>
                                <nav id="mobileNav" class="w-full md:w-auto hidden md:block">
                                        <ul class="flex flex-col md:flex-row gap-4 md:gap-6 items-center">
                                                <li><a href="/" class="text-gray-300 hover:text-white transition-colors block py-2 md:py-0">Home</a></li>
                                                <li><a href="/newsletter" class="text-gray-300 hover:text-white transition-colors block py-2 md:py-0 whitespace-nowrap">Games & Negotiations</a></li>
                                                <li><a href="/about" class="text-gray-300 hover:text-white transition-colors block py-2 md:py-0">About</a></li>
                                                <li><a href="/contact" class="text-gray-300 hover:text-white transition-colors block py-2 md:py-0">Contact</a></li>
                                        </ul>
                                </nav>
			</div>
		</header>
		<main class="flex-grow max-w-6xl mx-auto w-full p-4 md:p-8">
			
			<slot />
		</main>
		<footer class="py-8 px-4 mt-12 bg-dark border-t border-gray-800">
			<div class="max-w-6xl mx-auto">
				<div class="flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-sm text-gray-400">© 2025 Ahmed K. Hafsi. All Rights Reserved.</p>
					<div class="flex gap-4">
						<a href="https://negotiations.substack.com" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors">Substack</a>
						<a href="https://linkedin.com/in/ahmedkhalilhafsi" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors">LinkedIn</a>
					</div>
				</div>
			</div>
		</footer>
		
		<!-- Structured Data for SEO -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Ahmed K. Hafsi",
				"url": "https://ahmedhafsi.com",
				"sameAs": [
					"https://negotiations.substack.com",
					"https://linkedin.com/in/ahmedkhalilhafsi"
				],
				"jobTitle": "Negotiation Strategist",
				"worksFor": {
					"@type": "Organization",
					"name": "Infineon"
				},
				"description": "Expert in game theory and negotiation strategy with over a decade of experience."
			}
		</script>
		
		<script>
			// Mobile menu toggle
			document.addEventListener('DOMContentLoaded', () => {
				const menuBtn = document.getElementById('menuBtn');
				const mobileNav = document.getElementById('mobileNav');
				
                                if (menuBtn && mobileNav) {
                                        menuBtn.addEventListener('click', () => {
                                                mobileNav.classList.toggle('hidden');
                                        });
                                }
                        });
                </script>
	</body>
</html>

<style is:global>
	html {
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		-webkit-text-size-adjust: 100%;
	}
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Source Serif Pro', serif;
	}
	
	@media (max-width: 640px) {
		html {
			font-size: 14px;
		}
	}
	
	/* Improve touch targets on mobile */
	@media (max-width: 640px) {
		button, 
		[role="button"],
		a.button,
		input[type="submit"] {
			min-height: 44px;
			padding: 0.5rem 1rem;
		}
	}
	
        /* Dropdown styles intentionally removed along with Services menu */

        /* inter-300 - latin */
@font-face {
  font-display: swap; /* Check https://developer.mozilla.org/en-US/docs/Web/CSS/@font-face/font-display for other options. */
  font-family: 'Inter';
  font-style: normal;
  font-weight: 300;
  src: url('/fonts/inter/inter-v18-latin-300.woff2') format('woff2'); /* Chrome 36+, Opera 23+, Firefox 39+, Safari 12+, iOS 10+ */
}
/* inter-regular - latin */
